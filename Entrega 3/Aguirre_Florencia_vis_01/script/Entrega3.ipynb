# Pasar los datos a formato largo para que Altair pueda hacer dos líneas
datos_altair = polarizacion_vs_nulos_normalizado.melt(
    id_vars='anio',
    value_vars=['polarizacion_normalizada', 'nulos_normalizados'],
    var_name='variable',
    value_name='valor'
)

# Cambiar nombres para que se vean bonitos en la leyenda
datos_altair['variable'] = datos_altair['variable'].replace({
    'polarizacion_normalizada': 'Polarización normalizada',
    'nulos_normalizados': 'Voto nulo normalizado'
})

# Crear gráfico
grafico_polarizacion_vs_nulos = alt.Chart(datos_altair).mark_line(point=True).encode(
    x=alt.X(
        'anio:O',
        title='Año'
    ),
    y=alt.Y(
        'valor:Q',
        title='Índice normalizado (Máx. 100)',
        scale=alt.Scale(domain=[0, 105])
    ),
    color=alt.Color(
        'variable:N',
        title='Variable'
    ),
    tooltip=[
        alt.Tooltip('anio:O', title='Año'),
        alt.Tooltip('variable:N', title='Variable'),
        alt.Tooltip('valor:Q', title='Valor', format='.1f')
    ]
).properties(
    title='Evolución comparada de polarización y voto nulo',
    width=750,
    height=420
)

grafico_polarizacion_vs_nulos
grafico_polarizacion_vs_nulos.save("evolucion_polarizacion_vs_voto_nulo_normalizado.html")
grafico_polarizacion_vs_nulos.save("evolucion_polarizacion_vs_voto_nulo_normalizado.png")

