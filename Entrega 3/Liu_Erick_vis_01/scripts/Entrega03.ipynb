plt.figure(figsize=(10,6))

plt.plot(
    cantidad_vs_nulos['anio'],
    cantidad_vs_nulos['cantidad_candidatos'],
    marker='o',
    label='Cantidad de candidatos'
)

plt.plot(
    cantidad_vs_nulos['anio'],
    cantidad_vs_nulos['porcentaje_nulos'],
    marker='o',
    label='Votos nulos (%)'
)

plt.title('Cantidad de candidatos y voto nulo por año')
plt.xlabel('Año')
plt.ylabel('Valor')
plt.xticks(cantidad_vs_nulos['anio'], rotation=45)
plt.legend()
plt.grid(True)

plt.show()
